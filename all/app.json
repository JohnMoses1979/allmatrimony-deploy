{
  "expo": {
    "name": "all",
    "slug": "all",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone for voice questions.",
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to recognize your voice questions."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.all",
      "usesCleartextTraffic": true,
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c1c8d870-9ee5-468b-9b0b-ef2e3ed4d502"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone for voice questions.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to recognize your voice questions."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "owner": "jaya5242"
  }
}